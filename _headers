# Cache static assets aggressively (CSS/JS/images don't change between deploys
# without a content hash, but Cloudflare Pages auto-invalidates the CDN on each deploy)
/css/*
  Cache-Control: public, max-age=86400, must-revalidate
/js/*
  Cache-Control: public, max-age=86400, must-revalidate
/data/*
  Cache-Control: public, max-age=3600, must-revalidate
/icons/*
  Cache-Control: public, max-age=604800, immutable
/audio/*
  Cache-Control: public, max-age=2592000, immutable

# HTML should always revalidate so users get the latest version
/*.html
  Cache-Control: public, max-age=0, must-revalidate

# Security headers — applied to all responses
/*
  X-Frame-Options: SAMEORIGIN
  X-Content-Type-Options: nosniff
  Referrer-Policy: strict-origin-when-cross-origin
  Permissions-Policy: geolocation=(), microphone=(), camera=()
